{
  "name": "__MSG_appName__",
  "description": "__MSG_appDesc__",
  "version": "1.0.0",
  "default_locale": "es",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["storage", "activeTab", "tts"],
  "host_permissions": ["<all_urls>"],
  "background_script": "background/service-worker.js",
  "popup": "popup/popup.html",
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/messages.js",
        "utils/settings-store.js",
        "utils/tts.js",
        "utils/keyboard-nav.js",
        "content/dom-injector.js",
        "content/content-script.js",
        "content/floating-widget.js"
      ],
      "css": [
        "content/styles/themes.css",
        "content/styles/links-highlight.css",
        "content/styles/floating-widget.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": ["content/styles/*.css"],
  "firefox_id": "accesibilidad-web-universal@example.com",
  "firefox_strict_min_version": "91.0"
}
